PORT=5000
MONGO_URI=your_mongodb_connection_string_here
JWT_SECRET=replace_with_a_long_random_secret
# Access token lifetime (short-lived). Refresh tokens keep sessions alive for 30 days.
JWT_EXPIRES_IN=15m

# Set to "production" on your host. Controls secure/SameSite cookie flags,
# log format (JSON vs pretty), and Morgan format.
NODE_ENV=production

# Base URL of the frontend. Used for CORS and for building the links inside
# verification / password-reset emails (e.g. CLIENT_URL/verify-email?token=...).
CLIENT_URL=http://localhost:5173

# Resend (https://resend.com) — email delivery for verification & password reset.
# Create an API key in the Resend dashboard.
RESEND_API_KEY=your_resend_api_key_here
# The "from" address. Must be on a domain you've verified in Resend, or use
# the shared sandbox sender "onboarding@resend.dev" for local testing.
EMAIL_FROM=WriteBlog <onboarding@resend.dev>
